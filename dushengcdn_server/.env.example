# Copy this file to .env in the same directory, then edit values before running
# `docker compose up -d --build`. Keep the real .env out of Git.

DUSHENGCDN_VERSION=dev
DUSHENGCDN_HTTP_PORT=3010

POSTGRES_DB=dushengcdn
POSTGRES_USER=dushengcdn
POSTGRES_PASSWORD=replace-with-strong-password

SESSION_SECRET=replace-with-a-long-random-string
SQLITE_PATH=/data/dushengcdn.db
DSN=postgres://dushengcdn:replace-with-strong-password@postgres:5432/dushengcdn?sslmode=disable
DATABASE_MAX_OPEN_CONNS=30
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME_SECONDS=1800

GIN_MODE=release
LOG_LEVEL=info

# Optional compatibility token for old Agents deployed before node-specific tokens.
# New deployments should use discovery_token or node-specific agent_token instead.
# AGENT_TOKEN=replace-with-legacy-agent-token

# Optional Redis backend for rate limit/session-related runtime helpers.
# REDIS_CONN_STRING=redis://redis:6379/0
