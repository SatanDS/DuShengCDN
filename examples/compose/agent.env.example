DUSHENGCDN_VERSION=replace-with-release-version
DUSHENGCDN_SERVER_URL=https://cdn.example.com
DUSHENGCDN_AGENT_TOKEN=replace-with-agent-token

# Optional precise IP lookup API. Local GeoIP is used first; this API is queried only when local GeoIP has no country.
# DUSHENGCDN_GEOIP_LOOKUP_API_URL=https://ipdb.example.com/lookup
# DUSHENGCDN_GEOIP_LOOKUP_API_TOKEN=replace-with-api-token

LOG_LEVEL=info
