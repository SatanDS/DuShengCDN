DUSHENGCDN_VERSION=latest
DUSHENGCDN_DNS_WORKER_SERVER_URL=https://cdn.example.com
DUSHENGCDN_DNS_WORKER_TOKEN=replace-with-dns-worker-token
DUSHENGCDN_DNS_WORKER_LISTEN_ADDR=:53
DUSHENGCDN_DNS_WORKER_SNAPSHOT_PATH=/data/dns-worker-snapshot.json
DUSHENGCDN_DNS_WORKER_HEARTBEAT_INTERVAL=10s
DUSHENGCDN_DNS_WORKER_SNAPSHOT_MAX_AGE=5m
DUSHENGCDN_DNS_WORKER_QUERY_RATE_LIMIT=200
DUSHENGCDN_DNS_WORKER_UDP_RESPONSE_SIZE=1232

# Uncomment when country-code GSLB pools are used and the MMDB is mounted.
# DUSHENGCDN_DNS_WORKER_GEOIP_DATABASE_PATH=/geoip/GeoLite2-Country.mmdb

LOG_LEVEL=info
